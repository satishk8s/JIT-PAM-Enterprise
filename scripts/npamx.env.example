# NPAMX backend environment (example)
# Copy to: /etc/npamx/npamx.env (chmod 600) on the PAM server.
#
# Recommended for Docker on EC2:
# - keep only non-secret values in this file
# - keep secrets in Secrets Manager
# - start the container with scripts/run-docker-from-secrets.sh
#   so the EC2 host fetches secret values and injects them at runtime

# --- Production (required when FLASK_ENV=production) ---
# FLASK_ENV=production
# FLASK_SECRET_KEY_SECRET_NAME=npamx/prod/flask-secret-key
# APP_BASE_URL=https://npamx.nyk00-int.network
# CORS_ORIGINS=https://npamx.nyk00-int.network
# CONTENT_SECURITY_POLICY=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; object-src 'none'; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; script-src 'self' https://cdnjs.cloudflare.com; script-src-elem 'self' https://cdnjs.cloudflare.com; script-src-attr 'unsafe-inline'; connect-src 'self' https: ws: wss:
# In production, set all three explicitly. Do not rely on fallback CORS/CSP values.

# Optional: disable SAML verbose logging (set true only for dev)
# SAML_DEBUG=false

# Optional: disable /api/debug/* routes (set in production)
# DISABLE_DEBUG_ROUTES=1

# IAM Identity Center / SSO runtime
# Keep these in env or use *_SECRET_NAME via the host-side launcher.
SSO_INSTANCE_ARN_SECRET_NAME="npamx/prod/sso-instance-arn"
IDENTITY_STORE_ID_SECRET_NAME="npamx/prod/identity-store-id"
SSO_START_URL_SECRET_NAME="npamx/prod/sso-start-url"
SAML_IDP_METADATA_XML_SECRET_NAME="npamx/prod/saml-idp-metadata-xml"

# Vault nonprod runtime (required for current DB activation path)
VAULT_ADDR_NONPROD="https://<your-vault-host>:8200"
VAULT_CACERT_NONPROD="/absolute/path/to/vault-ca.pem"

# Recommended: AWS IAM auth from the NPAMx app EC2 instance role
VAULT_AUTH_METHOD_NONPROD="aws"
VAULT_AWS_ROLE_NONPROD="npamx-backend-iam"
VAULT_AWS_IAM_SERVER_ID_NONPROD="npamx-vault-nonprod"

# Legacy fallback: AppRole auth (keep only if you are not using AWS auth)
# VAULT_ROLE_ID_SECRET_NAME_NONPROD="vault/nonprod/pam-backend/role-id"
# VAULT_SECRET_ID_SECRET_NAME_NONPROD="vault/nonprod/pam-backend/secret-id"

# Vault DB secrets engine mount (connection names are engine-aware in code)
VAULT_DB_MOUNT_NONPROD="database"

# Current v1.1 direct DB testing path. Turn off when a reviewed proxy path exists.
DB_CONNECT_ALLOW_DIRECT_NONPROD="false"

# If/when a real DB access endpoint exists later, set these instead.
# DB_CONNECT_PROXY_HOST_NONPROD="db-access-nonprod.internal"
# DB_CONNECT_PROXY_PORT_NONPROD="3306"

# SQLite persistence (optional override)
# Default: <repo>/backend/data/npamx.db
NPAMX_DB_PATH="/var/lib/npamx/npamx.db"

# IAM DB auth / TLS (optional, recommended if you use IAM auth later)
DB_SSL_CA_BUNDLE="/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem"
DB_SSL_REQUIRE="true"

# DB admin (for MySQL user creation; do NOT use defaults in production)
# DB_ADMIN_USER=root
# DB_ADMIN_PASSWORD=<secure-password>

# Production runtime hardening
RATE_LIMIT_BACKEND="sqlite"
GUNICORN_WORKERS="1"
GUNICORN_THREADS="4"
NO_PROXY="169.254.169.254,127.0.0.1,localhost"
no_proxy="169.254.169.254,127.0.0.1,localhost"

# Optional only if you intentionally run backend/database_proxy.py
# DB_PROXY_INTERNAL_TOKEN_SECRET_NAME="npamx/prod/db-proxy-internal-token"
